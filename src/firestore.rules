rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: is this user a member of this company?
    function isMember(companyId) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }
    
    // Helper: get user role in company
    function getRole(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role;
    }
    
    // Helper: is admin?
    function isAdmin(companyId) {
      return isMember(companyId) && getRole(companyId) == 'admin';
    }
    
    // Helper: is admin or agent?
    function canEdit(companyId) {
      return isMember(companyId) && getRole(companyId) in ['admin', 'agent'];
    }

    // User profile - each user can read/write their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Companies - any authenticated user can CREATE (new company setup)
    // Only members can READ, only admin/agent can UPDATE
    match /companies/{companyId} {
      allow create: if request.auth != null;
      allow read: if isMember(companyId);
      allow update: if canEdit(companyId);
      allow delete: if false;
    }
    
    // Company members
    match /companies/{companyId}/members/{memberId} {
      allow create: if request.auth != null && request.auth.uid == memberId;
      allow read: if isMember(companyId);
      allow update, delete: if isAdmin(companyId);
    }
    
    // Legacy invites subcollection - scoped to company
    match /companies/{companyId}/invites/{inviteId} {
      allow read: if isMember(companyId);
      allow write: if canEdit(companyId);
    }
    
    // Top-level invites for joining
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy', 'usedAt', 'used']);
      allow delete: if false;
    }
    
    // Tracking - public read (client tracking links), authenticated write
    match /tracking/{trackingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Files - scoped by companyId field when present
    match /files/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

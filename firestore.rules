rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──

    function isAuth() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isMember(companyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function memberHasRole(companyId, roles) {
      return isMember(companyId) &&
        get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role in roles;
    }

    // Compte actif = pas de billing OU billingStatus != 'suspended'
    function isCompanyActive(companyId) {
      return !exists(/databases/$(database)/documents/companies/$(companyId)/billing/profile) ||
        get(/databases/$(database)/documents/companies/$(companyId)/billing/profile).data.billingStatus != 'suspended';
    }

    // Sprint 40 F40.1 — Fix P0.1 auto-adhesion.
    // 1er createur d'une company : autorise si la company n'existe pas encore.
    function isFirstCompanyCreator(companyId) {
      return !exists(/databases/$(database)/documents/companies/$(companyId));
    }

    // Sprint 40 F40.1 — Validation d'une invitation pour rejoindre une company.
    // Le client passe `inviteCode` dans le memberData. Les rules verifient :
    //  - L'invite existe sous /invites/{inviteCode}
    //  - companyId match
    //  - assignedEmail match l'email auth
    //  - non utilisee (usedBy absent ou null)
    //  - role du member doc == role de l'invite (pas de promotion)
    function hasValidInvite(companyId) {
      // Sprint 44 hotfix 2 : sans let (compat emulateur), check explicite a l'entree.
      //  1) Le doc membre DOIT contenir un champ inviteCode (string), sinon refuse.
      //  2) Le doc /invites/{code} DOIT exister.
      //  3) Validation companyId + assignedEmail + role + non utilisee.
      // L'ordre est important : on ne fait jamais get() si exists() est false.
      return request.resource.data.keys().hasAll(['inviteCode']) &&
        request.resource.data.inviteCode is string &&
        exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)) &&
        get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.companyId == companyId &&
        get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.assignedEmail == request.auth.token.email &&
        request.resource.data.role == get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.role &&
        (!('usedBy' in get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.keys()) ||
         get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.usedBy == null);
    }

    // ── Super-admins ──
    // Seed manuel via Firebase Console. isSuperAdmin() verifie cette collection.
    // Lecture autorisee pour l'UID concerne (le client verifie s'il est super-admin).
    match /superAdmins/{uid} {
      allow read: if isSuperAdmin() || (isAuth() && request.auth.uid == uid);
      allow write: if isSuperAdmin();
    }

    // ── User profile ──
    // Sprint 40 F40.1 — Fix P0.1.
    // CREATE : libre pour self (creation initiale du compte).
    // UPDATE : interdit modification de companyId / role par self (immutabilite).
    //          Super-admin peut tout (changement de company, suspension, etc.).
    // DELETE : super-admin uniquement.
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isSuperAdmin() ||
        (isAuth() && request.auth.uid == userId &&
         request.resource.data.companyId == resource.data.companyId &&
         request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    // ── Global config ──
    match /config/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Companies ──
    // CREATE : autorise seulement si la company n'existe pas encore (1er createur).
    // UPDATE :
    //   admin : peut tout modifier (cfg, name, arrays legacy)
    //   editor/agent : peut modifier les arrays operationnels (dos/tcs/chs/dep/logs)
    //                  MAIS pas les champs sensibles cfg/name (tarifs et identite societe).
    // DELETE : super-admin uniquement.
    // Sprint 44 F44.5 : durcissement granulaire via affectedKeys + admin-only fields.
    // Note (corrige Sprint 47) : affectedKeys() est BASE VALEUR — c'est diff(resource.data),
    // soit added union changed union removed. Un setDoc full-doc qui reecrit cfg/name a
    // l'identique ne les met PAS dans le diff. Cette rule est donc deja effective des la
    // Phase A, sans attendre updateDoc cible (l'ancienne note "effective Phase D" etait
    // une meprise sur la semantique d'affectedKeys).
    function changesAdminOnlyFields() {
      // Returns true si l'update touche un champ reserve admin
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['cfg', 'name']);
    }

    // ── Backlog O (Sprint 47) : champs financiers reserves, par tier ──
    // Field-level sur les sous-collections. Toutes ces fonctions s'appuient sur
    // diff(resource.data).affectedKeys() = BASE VALEUR : une reecriture a l'identique
    // (cas du mirror batch.set full-doc en Phase A) ne declenche PAS la rule. C'est ce
    // qui rend O compatible avec le write-model actuel, sans attendre updateDoc cible.
    // N'EST UTILISABLE QUE SUR update (resource.data existe). create reste permissif.
    // Tier 1 : admin-only. UNIQUEMENT les MONTANTS strategiques (recette, profit, montants
    // de garantie). gar_statut/gar_contact/gar_tel sont des ETATS OPERATIONNELS (constatation
    // d'un fait : caution versee/recuperee, coordonnees), pas des engagements chiffres : ils
    // restent libres (editor/agent), traces par wLog. Cf. reclassification Sprint 47 (4-eyes
    // ecarte sur les statuts : la separation des pouvoirs porte sur les CHIFFRES, pas les
    // ETIQUETTES). Tier 2 (ex-statut paiement dep) dissous pour la meme raison.
    function changesDossierFinanceFields() {   // Tier 1 : admin-only (montants strategiques)
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rv', 'pf', 'gar_frais', 'gar_caution', 'gar_frais_unit', 'gar_caution_unit']);
    }
    function changesDepAmountFields() {        // Tier 3 : admin+editor, pas agent (montants)
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['mt', 'ht']);
    }
    function changesTcPriceField() {           // Tier 3 : admin+editor, pas agent (prix chauffeur)
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['pc']);
    }
    match /companies/{companyId} {
      allow create: if isAuth() && isFirstCompanyCreator(companyId);
      allow read: if isAuth() && (isSuperAdmin() || isMember(companyId));
      allow update: if isSuperAdmin() || (
        isCompanyActive(companyId) && (
          // Admin : peut tout
          memberHasRole(companyId, ['admin']) ||
          // Editor/agent : peut modifier les arrays operationnels SI aucun champ admin-only ne change
          (memberHasRole(companyId, ['editor', 'agent']) && !changesAdminOnlyFields())
        )
      );
      allow delete: if isSuperAdmin();
    }

    // ── Company members ──
    // Sprint 40 F40.1 — Fix P0.1.
    // CREATE :
    //  - super-admin : libre
    //  - 1er membre d'une nouvelle company : autorise (createCompany)
    //  - autres : exige une invitation valide (hasValidInvite)
    //  Dans tous les cas, on cree son propre member doc (request.auth.uid == memberId).
    // UPDATE / DELETE : super-admin ou admin de la company (et un admin ne peut pas se retirer).
    match /companies/{companyId}/members/{memberId} {
      allow read: if isSuperAdmin() || isMember(companyId);

      allow create: if isSuperAdmin() || (
        // Sprint 44 hotfix 2 : 2 branches mutuellement exclusives pour eviter
        // qu'une evaluation laxiste laisse passer un write sans inviteCode.
        resource == null &&
        isAuth() && request.auth.uid == memberId && (
          // BRANCHE 1 : 1er createur d'une company qui n'existe pas + PAS d'inviteCode
          (isFirstCompanyCreator(companyId) &&
           !request.resource.data.keys().hasAll(['inviteCode']))
          ||
          // BRANCHE 2 : invitation valide (inviteCode obligatoire) sur company existante
          (request.resource.data.keys().hasAll(['inviteCode']) &&
           hasValidInvite(companyId))
        )
      );

      allow update: if isSuperAdmin() || (
        memberHasRole(companyId, ['admin']) && isCompanyActive(companyId)
      );

      // Un admin ne peut pas se retirer lui-meme (evite le verrouillage).
      // Super-admin peut tout supprimer.
      allow delete: if isSuperAdmin() || (
        memberHasRole(companyId, ['admin']) && isCompanyActive(companyId) &&
        memberId != request.auth.uid
      );
    }

    // ── Sprint 43 Phase A : sous-collections dual-write ──
    // Sprint 44 F44.3 : permissions durcies par role + immutabilite des logs.
    //
    // Phase A : ces rules autorisent le miroir fire-and-forget depuis save().
    // Phase C (Sprint 45+) : deviennent authoritative quand les listeners switchent.
    //
    // Matrice :
    //   admin    : tout (create, update, delete sur toutes les sous-collections)
    //   editor   : tout sauf delete des dossiers cloturees (audit trail metier)
    //   agent    : update dossiers/tcs/dep, pas de delete, pas de chauffeurs
    //   viewer   : read only
    //
    // Logs : APPEND-ONLY (create autorise, update/delete bloque sauf super-admin).

    match /companies/{companyId}/dossiers/{dosId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      // Sprint 47 (backlog O) : update verrouille field-level. Create reste permissif —
      // l'UI masque les financiers a la creation (NDosForm: inputs gates par mode edition)
      // et le payload create est neutre (rv/pf/gar_*=0). Le vecteur de fraude (mutation des
      // financiers) est sur update, traite ci-dessous.
      allow create: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor', 'agent']) && isCompanyActive(companyId));
      allow update: if isSuperAdmin() || (isCompanyActive(companyId) && (
        memberHasRole(companyId, ['admin']) ||
        (memberHasRole(companyId, ['editor', 'agent']) && !changesDossierFinanceFields())
      ));
      // Delete : admin uniquement (les editor/agent ne peuvent pas effacer un dossier)
      allow delete: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin']) && isCompanyActive(companyId));
    }

    match /companies/{companyId}/tcs/{tcId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      allow create: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor', 'agent']) && isCompanyActive(companyId));
      // Sprint 47 (backlog O) : pc (prix chauffeur) = Tier 3, admin+editor ; agent exclu.
      allow update: if isSuperAdmin() || (isCompanyActive(companyId) && (
        memberHasRole(companyId, ['admin', 'editor']) ||
        (memberHasRole(companyId, ['agent']) && !changesTcPriceField())
      ));
      allow delete: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor']) && isCompanyActive(companyId));
    }

    match /companies/{companyId}/chs/{chId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      // Chauffeurs : geres par admin/editor uniquement (agent ne cree pas de chauffeurs)
      allow create, update, delete: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor']) && isCompanyActive(companyId));
    }

    match /companies/{companyId}/dep/{depId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      allow create: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor', 'agent']) && isCompanyActive(companyId));
      // Sprint 47 (backlog O) : seuls les montants (mt/ht) = Tier 3, admin+editor, agent
      // exclu. Le statut paiement (s/status) est un etat operationnel libre (ex-Tier 2
      // dissous a la reclassification) : un toggle IMPAYE->PAYE est une constatation tracee
      // par wLog, pas une signature financiere.
      allow update: if isSuperAdmin() || (isCompanyActive(companyId) && (
        memberHasRole(companyId, ['admin', 'editor']) ||
        (memberHasRole(companyId, ['agent']) && !changesDepAmountFields())
      ));
      // Delete : admin/editor uniquement (un agent ne supprime pas une depense)
      allow delete: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor']) && isCompanyActive(companyId));
    }

    // ── Sprint 44 instrumentation : observabilite dual-write ──
    // Sous-collection cree par persistMirrorErrors() quand un mirror echoue.
    // Lecture/ecriture reserve admin (et bien sur super-admin pour audit cross-tenant).
    // Read : admin uniquement pour ne pas exposer des messages d'erreur a editor/agent.
    // Create : tout member actif peut ecrire (le mirror tourne sous leur session).
    // Update/Delete : super-admin uniquement (immutabilite pour audit).
    match /companies/{companyId}/dual_write_errors/{errId} {
      allow read: if isSuperAdmin() || memberHasRole(companyId, ['admin']);
      allow create: if isSuperAdmin() ||
        (isMember(companyId) && isCompanyActive(companyId));
      allow update, delete: if isSuperAdmin();
    }

        match /companies/{companyId}/logs/{logId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      // Append-only : create autorise pour tout member actif, update/delete bloques.
      // Super-admin peut tout (cleanup admin).
      allow create: if isSuperAdmin() ||
        (memberHasRole(companyId, ['admin', 'editor', 'agent']) && isCompanyActive(companyId));
      allow update, delete: if isSuperAdmin();
    }

    // ── Billing (sous-collection) ──
    // Lecture par membres de la company + super-admin. Ecriture super-admin uniquement.
    match /companies/{companyId}/billing/{billingDoc} {
      allow read: if isSuperAdmin() || isMember(companyId);
      allow write: if isSuperAdmin();
    }

    // ── Notifications ──
    match /companies/{companyId}/notifications/{notifId} {
      allow read: if isSuperAdmin() || isMember(companyId);
      allow create: if isSuperAdmin() || (memberHasRole(companyId, ['admin', 'editor']) && isCompanyActive(companyId));
      allow update: if isSuperAdmin() || (isMember(companyId) && isCompanyActive(companyId));
      allow delete: if isSuperAdmin();
    }

    // ── Legacy invites subcollection ──
    match /companies/{companyId}/invites/{inviteId} {
      allow read: if isAuth();
      allow create, delete: if isSuperAdmin() || (
        memberHasRole(companyId, ['admin']) && isCompanyActive(companyId)
      );
    }

    // ── Top-level invites ──
    // Sprint 40 F40.1 — Fix P0.1.
    // CREATE : exige que le createur soit ADMIN de la company concernee.
    // UPDATE : seul le destinataire peut marquer l'invite comme usedBy (acceptation).
    // DELETE : le destinataire ou un admin de la company.
    match /invites/{code} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.companyId is string
        && request.resource.data.createdBy is string
        && request.resource.data.assignedEmail is string
        && isCompanyActive(request.resource.data.companyId)
        && memberHasRole(request.resource.data.companyId, ['admin']);
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy'])
        && request.resource.data.usedBy == request.auth.uid
        && resource.data.assignedEmail == request.auth.token.email;
      allow delete: if isAuth() && (
        resource.data.usedBy == request.auth.uid ||
        (memberHasRole(resource.data.companyId, ['admin']) && isCompanyActive(resource.data.companyId))
      );
    }

    // ── Tracking (public read, write par membre actif) ──
    // Sprint 40 F40.1 — defense en profondeur : check membership en plus de users.companyId.
    match /tracking/{trackingId} {
      allow read: if true;

      allow write: if isAuth()
        && request.resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
        && isMember(request.resource.data.companyId)
        && isCompanyActive(request.resource.data.companyId);

      allow update: if resource != null
        && resource.data.rating == null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'ratingComment', 'ratingReasons', 'ratingAt'])
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasAll(['rating', 'ratingAt'])
        && request.resource.data.rating in [1, 2, 3]
        && request.resource.data.ratingAt == request.time
        && (!('ratingComment' in request.resource.data.keys())
            || (request.resource.data.ratingComment is string
                && request.resource.data.ratingComment.size() <= 200))
        && (!('ratingReasons' in request.resource.data.keys())
            || (request.resource.data.ratingReasons is list
                && request.resource.data.ratingReasons.size() <= 5));
    }

    // ── Files (base64 storage) ──
    // Sprint 40 F40.1 — defense en profondeur :
    //  users.companyId est desormais immutable cote rules (sauf via super-admin),
    //  mais on AJOUTE en plus un check de membership pour bloquer le cas ou
    //  un utilisateur aurait deja un companyId frauduleux historique.
    match /files/{fileId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        (isMember(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId) &&
         fileId.matches('lt-file-' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId + '-.*'))
      );
      allow create, update: if isAuth()
        && isMember(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId)
        && isCompanyActive(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId)
        && fileId.matches('lt-file-' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId + '-.*');
      allow delete: if isSuperAdmin()
        || (isAuth()
          && isMember(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId)
          && isCompanyActive(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId)
          && fileId.matches('lt-file-' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId + '-.*'));
    }
  }
}
